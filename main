import os
import numpy as np
from PIL import Image
from tensorflow.keras.models import load_model #ignore
import cv2
import magic

IMAGE_DIR = input("Enter the file path: ")
MODEL_PATH = ""
TAGS_PATH  = ""

IMAGE_SIZE = 512
IMAGE_THRESHOLD = 0.25
VIDEO_THRESHOLD = 0.65

def load_tags(path):
    with open(path, "r", encoding="utf-8") as f:
        tags = [line.strip() for line in f if line.strip()]
    return tags

def load_image(path):
        img = Image.open(path).convert("RGB")
        img = img.resize((IMAGE_SIZE, IMAGE_SIZE), Image.BICUBIC)
        img = np.asarray(img, dtype=np.float32) / 255.0
        return np.expand_dims(img, axis=0)

def extract_quarter_frames(video_path):
    cap = cv2.VideoCapture(video_path)

    if not cap.isOpened():
        print(f"Failed to open video: {video_path}")
        return []

    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))

    # Frame indices at 1/4, 2/4, 3/4
    target_frames = [
        total_frames // 4,
        total_frames // 2,
        (3 * total_frames) // 4
    ]

    frames = []

    for frame_no in target_frames:
        cap.set(cv2.CAP_PROP_POS_FRAMES, frame_no)
        ret, frame = cap.read()
        if not ret:
            continue

        # Convert BGR (OpenCV) → RGB (PIL format)
        frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

        # Resize and normalize like your load_image()
        frame = cv2.resize(frame, (IMAGE_SIZE, IMAGE_SIZE))
        frame = frame.astype(np.float32) / 255.0
        frame = np.expand_dims(frame, axis=0)

        frames.append(frame)

    cap.release()
    return frames


def main():
    model = load_model(MODEL_PATH, compile=False)
    tags = load_tags(TAGS_PATH)
    path = IMAGE_DIR

    print("Model outputs:", model.output_shape[-1])
    print("Tag count:   ", len(tags))

    if model.output_shape[-1] != len(tags):
        raise RuntimeError("Tag count does not match model output size!")

    for fn in sorted(os.listdir(IMAGE_DIR)):
        path = os.path.join(IMAGE_DIR, fn)

        if fn.lower().endswith((".png", ".jpg", ".jpeg", ".webp")):
            images = [load_image(path)]
            threshold = IMAGE_THRESHOLD

        elif fn.lower().endswith((".mp4", ".mkv", ".avi", ".webm")):
            images = extract_quarter_frames(path)
            if not images:
                continue
            threshold = VIDEO_THRESHOLD

        else:
            continue

        path = os.path.join(IMAGE_DIR, fn)
        all_preds = []

        for image in images:
            preds = model.predict(image, verbose=0)[0]
            all_preds.append(preds)

        # Average predictions across frames (better tagging)
        preds = np.mean(all_preds, axis=0)

        selected = [
            tags[i].replace("_", " ")
            for i, score in enumerate(preds)
            if score >= threshold
        ]

        out = os.path.splitext(path)[0] + ".txt"
        with open(out, "w", encoding="utf-8") as f:
            f.write("\n".join(selected))

        print(f"{fn}: {len(selected)} tags")

    print("Done.")


if __name__ == "__main__":
    main()
